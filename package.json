{
  "name": "@meri-imperiumi/signalk-reticulum",
  "version": "0.1.0",
  "description": "Signal K integration with the Reticulum network",
  "main": "plugin/index.js",
  "scripts": {
    "lint": "npx @biomejs/biome check --use-editorconfig=true plugin/",
    "format": "npx @biomejs/biome check --use-editorconfig=true --write plugin/ tests/",
    "test": "node --test --test-force-exit \"tests/*.test.js\""
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/meri-imperiumi/signalk-reticulum.git"
  },
  "keywords": [
    "reticulum",
    "rns",
    "signalk-node-server-plugin",
    "signalk-category-notifications"
  ],
  "author": "Henri Bergius <henri.bergius@iki.fi>",
  "license": "EUPL-1.2",
  "bugs": {
    "url": "https://github.com/meri-imperiumi/signalk-reticulum/issues"
  },
  "homepage": "https://github.com/meri-imperiumi/signalk-reticulum#readme",
  "signalk-plugin-enabled-by-default": false,
  "signalk": {
    "appIcon": "./doc/signalk-reticulum.png",
    "displayName": "Reticulum Network",
    "screenshots": [
      "./doc/alerts.jpg",
      "./doc/telemetry-position.jpg",
      "./doc/nomadnet.png"
    ]
  },
  "dependencies": {
    "@digitaldefiance/bzip2-wasm": "^1.1.1",
    "@reticulum/core": "^0.4.1",
    "@reticulum/node": "^0.4.1"
  },
  "devDependencies": {
    "@signalk/server-api": "^2.30.0"
  }
}
